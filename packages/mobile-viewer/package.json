{
  "name": "@desk/mobile-viewer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start:native": "react-native start --host 0.0.0.0",
    "package:android": "node scripts/package-native.mjs android",
    "package:ios:sim": "node scripts/package-native.mjs ios-sim",
    "package:ios:ipa": "node scripts/package-native.mjs ios-ipa",
    "e2e:native:ios": "node scripts/run-native-e2e.mjs ios",
    "e2e:native:android": "node scripts/run-native-e2e.mjs android",
    "e2e:native:real:ios": "node scripts/run-native-real-e2e.mjs ios",
    "e2e:native:real:android": "node scripts/run-native-real-e2e.mjs android",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.native.json --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run"
  },
  "dependencies": {
    "@desk/shared": "workspace:*",
    "@desk/signaling": "workspace:*",
    "@react-native/new-app-screen": "0.85.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-webrtc": "124.0.7"
